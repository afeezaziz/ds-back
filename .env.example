# Copy to .env for local docker-compose, or set these in Coolify's env UI.
# NEVER commit a real .env (it is gitignored).

# REQUIRED in production: a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-string-0123456789abcdef

# docker-compose uses this for the bundled Postgres. For a Coolify-managed
# Postgres instead, ignore this and set DATABASE_URL directly.
POSTGRES_PASSWORD=change-me-too

# Only needed when deploying the Dockerfile alone against an external Postgres:
# DATABASE_URL=postgresql://user:pass@host:5432/dreamstudio

# Apply seed.py (game catalog + remote configs) on every boot. Recommended.
SEED_ON_START=1
